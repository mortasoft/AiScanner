# -------------------------------------------------------------
# AiScanner Configuration / Environment Variables
# -------------------------------------------------------------

# ====================
# HOST PORTS EXPOSED
# ====================
# Modify these if your host machine already uses these ports. 
# These are the ports you will access from your browser/machine.
FRONTEND_PORT=43210
BACKEND_PORT=43211


# ====================
# DATABASE (MariaDB)
# ====================
MYSQL_ROOT_PASSWORD=rootpassword_secure_example
MYSQL_DATABASE=aiscanner
MYSQL_USER=aiscanner_user
MYSQL_PASSWORD=aiscanner_password_strong
MYSQL_PORT=3307

# ====================
# API URLS & CONTAINERS
# ====================
# The URL where the frontend expects the FastAPI backend to be:
# (Use 'localhost' for development on this machine, use the IP for network access)
VITE_API_URL=http://localhost:43211
# VITE_API_URL=http://192.168.100.3:${BACKEND_PORT}

# External API dependencies for Scanners:
NESSUS_API_URL=https://nessus:8834
OPENVAS_API_URL=https://openvas:9392
