<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>NEXUS | SecOps Scanner</title>
    <style>
        /* --- SAME CSS AS BEFORE (Kept concise for brevity) --- */
        :root {
            --bg-dark: #050509;
            --bg-panel: #0f0f16;
            --neon-cyan: #00f3ff;
            --neon-green: #00ff41;
            --neon-red: #ff003c;
            --text-main: #e0e0e0;
            --font-mono: 'Courier New', monospace;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: sans-serif;
            height: 100vh;
            display: flex;
            overflow: hidden;
            background-image: linear-gradient(rgba(0, 243, 255, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 243, 255, 0.03) 1px, transparent 1px);
            background-size: 30px 30px;
        }

        .sidebar {
            width: 260px;
            background: var(--bg-panel);
            border-right: 1px solid rgba(0, 243, 255, 0.2);
            padding: 20px;
            display: flex;
            flex-direction: column;
        }

        .brand {
            color: var(--neon-cyan);
            font-size: 1.5rem;
            margin-bottom: 40px;
            font-family: var(--font-mono);
        }

        .nav-item {
            padding: 15px;
            cursor: pointer;
            color: #888;
            font-family: var(--font-mono);
            margin-bottom: 5px;
            border-radius: 4px;
            transition: all 0.3s;
        }

        .nav-item.active,
        .nav-item:hover {
            color: var(--neon-cyan);
            background: rgba(0, 243, 255, 0.05);
            border-left: 3px solid var(--neon-cyan);
        }

        .main-content {
            flex: 1;
            padding: 30px;
            overflow-y: auto;
        }

        .module {
            display: none;
            animation: fadeIn 0.5s;
        }

        .module.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header {
            background: var(--bg-panel);
            border-bottom: 1px solid rgba(0, 243, 255, 0.2);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .scan-controls {
            background: var(--bg-panel);
            padding: 20px;
            border: 1px solid #333;
            margin-bottom: 20px;
            display: grid;
            grid-template-columns: 1fr 2fr auto;
            gap: 15px;
        }

        input,
        select {
            background: #000;
            border: 1px solid #333;
            color: var(--neon-cyan);
            padding: 10px;
            width: 100%;
            font-family: var(--font-mono);
        }

        .btn-scan {
            background: transparent;
            border: 1px solid var(--neon-red);
            color: var(--neon-red);
            padding: 0 30px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-scan:hover {
            background: var(--neon-red);
            color: #000;
            box-shadow: 0 0 15px var(--neon-red);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-family: var(--font-mono);
        }

        th,
        td {
            padding: 12px;
            border-bottom: 1px solid #333;
            text-align: left;
        }

        th {
            color: var(--neon-cyan);
        }

        .status-badge {
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 0.8rem;
        }

        .st-PENDING {
            color: #888;
            border: 1px solid #888;
        }

        .st-RUNNING {
            color: var(--neon-cyan);
            border: 1px solid var(--neon-cyan);
            animation: blink 1s infinite;
        }

        .st-COMPLETED {
            color: var(--neon-green);
            border: 1px solid var(--neon-green);
        }

        .st-FAILED {
            color: var(--neon-red);
            border: 1px solid var(--neon-red);
        }

        @keyframes blink {
            50% {
                opacity: 0.5;
            }
        }

        /* Modal Styles */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: var(--bg-panel);
            border: 1px solid var(--neon-cyan);
            width: 80%;
            max-width: 800px;
            max-height: 90vh;
            display: flex;
            flex-direction: column;
            box-shadow: 0 0 20px rgba(0, 243, 255, 0.2);
        }

        .modal-header {
            padding: 15px;
            border-bottom: 1px solid #333;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(0, 243, 255, 0.05);
        }

        .modal-body {
            padding: 20px;
            overflow-y: auto;
            flex: 1;
        }

        .modal-footer {
            padding: 15px;
            border-top: 1px solid #333;
            text-align: right;
        }

        .close-btn {
            background: transparent;
            border: none;
            color: #888;
            font-size: 1.5rem;
            cursor: pointer;
        }

        .close-btn:hover {
            color: var(--neon-red);
        }
    </style>
    <script src="//unpkg.com/3d-force-graph"></script>
</head>

<body>

    <nav class="sidebar">
        <div class="brand">[☢] NEXUS</div>
        <div class="nav-item active" onclick="switchModule('scanner')">⚡ Active Scanner</div>
        <div class="nav-item" onclick="switchModule('hosts')">🌐 Hosts & Graph</div>
        <div class="nav-item" onclick="switchModule('methodology')">📘 Methodology</div>
        <div style="margin-top: auto; color: #555; font-size: 0.8rem; text-align: center;">v{{ version }}</div>
    </nav>

    <main class="main-content">

        <!-- SCANNER MODULE -->
        <div id="scanner-module" class="module active">
            <section>
                <h2 style="color:white; margin-bottom:20px;">Target Acquisition</h2>
                <div class="scan-controls">
                    <div>
                        <label style="color:#888; font-size:0.8rem">TARGET</label>
                        <input type="text" id="targetInput" placeholder="127.0.0.1 or example.com">
                    </div>
                    <div>
                        <label style="color:#888; font-size:0.8rem">PROFILE</label>
                        <select id="toolSelect">
                            <option value="nmap">Nmap Fast Scan (nmap -F &lt;target&gt;)</option>
                            <option value="intense">Nmap Intense (nmap -T4 -A -v &lt;target&gt;)</option>
                            <option value="os_scan">Identify OS (nmap -O &lt;target&gt;)</option>
                            <option value="ping_scan">Ping Scan Network (nmap -sn &lt;target&gt;/24)</option>
                        </select>
                    </div>
                    <button class="btn-scan" onclick="initiateScan()">EXECUTE</button>
                </div>
            </section>

            <!-- HISTORY TABLE -->
            <section>
                <h2 style="color:white; margin-bottom:20px; margin-top: 40px;">Operation History</h2>
                <div style="background: var(--bg-panel); padding:10px;">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Target</th>
                                <th>Tool</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="dbBody">
                            <!-- Loaded via JS -->
                        </tbody>
                    </table>
                </div>
            </section>
        </div>

        <!-- METHODOLOGY MODULE -->
        <div id="methodology-module" class="module">
            <h2 style="color:var(--neon-cyan); border-bottom: 1px solid #333; padding-bottom: 10px;">Security Assessment
                Methodology</h2>

            <div style="margin-top: 20px; color: #ddd; line-height: 1.6;">
                <h3 style="color:var(--neon-green)">1. Reconnaissance (Information Gathering)</h3>
                <p>The first phase involves gathering as much information as possible about the target without directly
                    interacting with it in a way that triggers alarms.</p>
                <ul>
                    <li><strong>Passive Recon:</strong> WHOIS lookups, DNS enumeration, OSINT (Open Source
                        Intelligence).</li>
                    <li><strong>Active Recon:</strong> Ping sweeps, port scanning (Nmap), service version detection.
                    </li>
                </ul>

                <h3 style="color:var(--neon-green)">2. Scanning & Enumeration</h3>
                <p>Identify open ports, running services, and potential vulnerabilities.</p>
                <ul>
                    <li>Use <code>nmap -sV</code> to determine service versions.</li>
                    <li>Use <code>nmap -O</code> for OS detection.</li>
                    <li>Enumerate user accounts, shares, and DNS entries.</li>
                </ul>

                <h3 style="color:var(--neon-green)">3. Vulnerability Analysis</h3>
                <p>Analyze the gathered data to identify security weaknesses.</p>
                <ul>
                    <li>Check for known CVEs (Common Vulnerabilities and Exposures) associated with detected service
                        versions.</li>
                    <li>Use vulnerability scanners (e.g., Nessus, OpenVAS) if applicable.</li>
                </ul>

                <h3 style="color:var(--neon-green)">4. Exploitation</h3>
                <p>Attempt to compromise the system by exploiting identified vulnerabilities.</p>
                <ul>
                    <li>Use frameworks like Metasploit.</li>
                    <li><strong>Note:</strong> Always have explicit permission before attempting exploitation.</li>
                </ul>

                <h3 style="color:var(--neon-green)">5. Reporting</h3>
                <p>Document findings, evidence, and remediation recommendations.</p>
                <ul>
                    <li>Categorize findings by severity (Critical, High, Medium, Low).</li>
                    <li>Provide clear steps to reproduce and fix the issues.</li>
                </ul>
            </div>
        </div>

        <div id="hosts-module" class="module">
            <h2 style="color:white; margin-bottom:20px;">Discovered Hosts & Network Graph</h2>
            <div style="display: flex; flex-direction: column; gap: 20px;">
                <!-- Table -->
                <div style="background: var(--bg-panel); padding: 10px; max-height: 300px; overflow-y: auto;">
                    <h3>Host List</h3>
                    <table>
                        <thead>
                            <tr>
                                <th>IP Address</th>
                                <th>Hostname</th>
                                <th>Operating System</th>
                            </tr>
                        </thead>
                        <tbody id="hostsBody"></tbody>
                    </table>
                </div>
                <!-- Graph -->
                <div id="3d-graph" style="height: 500px; background: #000; border: 1px solid #333;"></div>
            </div>
        </div>

    </main>

    <!-- MODAL -->
    <div id="scanModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3 style="margin:0; color:var(--neon-cyan)">Scan Details <span id="modalScanId"
                        style="color:#888; font-size:0.8rem"></span></h3>
                <button class="close-btn" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <h4 style="color:white; margin-top:0">Open Ports</h4>
                <table style="margin-bottom:20px;">
                    <thead>
                        <tr>
                            <th>Port</th>
                            <th>Protocol</th>
                            <th>State</th>
                            <th>Service</th>
                        </tr>
                    </thead>
                    <tbody id="modalPortsBody"></tbody>
                </table>

                <h4 style="color:white">Raw Output</h4>
                <div class="terminal-window" id="modalRawOutput" style="height: 200px;"></div>
            </div>
            <div class="modal-footer">
                <button onclick="closeModal()"
                    style="background:#333; color:white; border:1px solid #555; padding:8px 15px; cursor:pointer;">CLOSE</button>
            </div>
        </div>
    </div>

    <script>
        // Initial load
        loadHistory();
        // Auto-refresh every 5 seconds
        setInterval(loadHistory, 5000);

        function switchModule(moduleId) {
            // Hide all modules
            document.querySelectorAll('.module').forEach(el => el.classList.remove('active'));
            // Deactivate all nav items
            document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));

            // Show selected module
            document.getElementById(moduleId + '-module').classList.add('active');

            // Activate nav item
            if (moduleId === 'scanner') {
                document.querySelectorAll('.nav-item')[0].classList.add('active');
            } else if (moduleId === 'hosts') {
                document.querySelectorAll('.nav-item')[1].classList.add('active');
                loadHosts();
            } else if (moduleId === 'methodology') {
                document.querySelectorAll('.nav-item')[2].classList.add('active');
            }
        }

        async function loadHosts() {
            const tbody = document.getElementById('hostsBody');
            tbody.innerHTML = '<tr><td colspan="3">Loading...</td></tr>';

            const res = await fetch('/api/hosts');
            const data = await res.json();

            // Populate Table
            tbody.innerHTML = '';

            // Neon color palette
            const neonColors = ['#00f3ff', '#00ff41', '#ff003c', '#ff00ff', '#ffff00', '#ff6600', '#00ffff', '#ff0099'];

            // Group hosts by subnet
            const subnetMap = {};
            const nodes = [{ id: "NEXUS", group: 0, color: '#ffffff' }];
            const links = [];

            data.forEach(host => {
                // Table
                const tr = document.createElement('tr');
                tr.innerHTML = `<td>${host.ip}</td><td>${host.hostname || '-'}</td><td>${host.os || 'Unknown'}</td>`;
                tbody.appendChild(tr);

                // Extract subnet (first 3 octets for /24)
                const subnet = host.ip.split('.').slice(0, 3).join('.');

                if (!subnetMap[subnet]) {
                    subnetMap[subnet] = {
                        color: neonColors[Object.keys(subnetMap).length % neonColors.length],
                        hosts: []
                    };
                    // Add subnet node
                    nodes.push({ id: subnet, group: 1, color: subnetMap[subnet].color });
                    // Link NEXUS to subnet
                    links.push({ source: "NEXUS", target: subnet });
                }

                // Add host to subnet
                subnetMap[subnet].hosts.push(host.ip);
                // Add host node
                nodes.push({ id: host.ip, group: 2, color: subnetMap[subnet].color });
                // Link subnet to host
                links.push({ source: subnet, target: host.ip });
            });

            // Render Graph
            const Graph = ForceGraph3D()
                (document.getElementById('3d-graph'))
                .graphData({ nodes, links })
                .nodeColor(node => node.color)
                .nodeLabel('id')
                .nodeRelSize(6)
                .linkWidth(2)
                .backgroundColor('#000000');
        }

        async function initiateScan() {
            const target = document.getElementById('targetInput').value;
            const tool = document.getElementById('toolSelect').value;
            const btn = document.querySelector('.btn-scan');

            if (!target) return alert("Target required!");

            btn.disabled = true;
            btn.innerText = "STARTING...";

            try {
                // 1. Send Start Request
                const res = await fetch('/api/scan', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ target, tool })
                });
                const data = await res.json();

                if (data.scan_id) {
                    // Refresh immediately to show new PENDING scan
                    loadHistory();
                }

            } catch (err) {
                alert(`Connection Error: ${err}`);
            } finally {
                // Reset button immediately - non-blocking
                btn.disabled = false;
                btn.innerText = "EXECUTE";
            }
        }

        async function loadHistory() {
            const tbody = document.getElementById('dbBody');

            const res = await fetch('/api/history');
            const data = await res.json();

            tbody.innerHTML = '';
            data.forEach(row => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>#${row.id}</td>
                    <td>${row.target}</td>
                    <td>${row.tool}</td>
                    <td><span class="status-badge st-${row.status}">${row.status}</span></td>
                    <td>${new Date(row.created_at).toLocaleString()}</td>
                    <td>
                        <button onclick="viewOutput(${row.id})" style="background:#333; color:white; border:none; cursor:pointer; padding:2px 5px;">VIEW</button>
                        <a href="/api/download/${row.id}" target="_blank" style="background:#00f3ff; color:black; text-decoration:none; padding:2px 5px; font-size:0.8rem; margin-left:5px;">PDF</a>
                        <button onclick="deleteScan(${row.id})" style="background:#ff003c; color:white; border:none; cursor:pointer; padding:2px 5px; margin-left:5px;">DELETE</button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        async function viewOutput(id) {
            const modal = document.getElementById('scanModal');
            const modalScanId = document.getElementById('modalScanId');
            const portsBody = document.getElementById('modalPortsBody');
            const rawOutput = document.getElementById('modalRawOutput');

            // Reset
            modalScanId.innerText = `(#${id})`;
            portsBody.innerHTML = '<tr><td colspan="4">Loading...</td></tr>';
            rawOutput.innerText = 'Loading...';
            modal.style.display = 'flex';

            try {
                const res = await fetch(`/api/status/${id}`);
                const data = await res.json();

                // Populate Ports
                portsBody.innerHTML = '';
                if (data.results && data.results.length > 0) {
                    data.results.forEach(port => {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td>${port.port}</td>
                            <td>${port.protocol}</td>
                            <td><span class="status-badge st-COMPLETED">${port.state}</span></td>
                            <td>${port.service}</td>
                        `;
                        portsBody.appendChild(tr);
                    });
                } else {
                    portsBody.innerHTML = '<tr><td colspan="4" style="text-align:center; color:#888;">No open ports found or scan failed.</td></tr>';
                }

                // Populate Raw Output
                rawOutput.innerText = data.output || 'No output available.';

            } catch (err) {
                rawOutput.innerText = `Error loading details: ${err}`;
            }
        }

        function closeModal() {
            document.getElementById('scanModal').style.display = 'none';
        }

        async function deleteScan(id) {
            if (!confirm(`Are you sure you want to delete scan #${id}? This will remove all related data.`)) {
                return;
            }

            try {
                const res = await fetch(`/api/delete/${id}`, { method: 'DELETE' });
                const data = await res.json();

                if (data.success) {
                    loadHistory();
                } else {
                    alert('Failed to delete scan');
                }
            } catch (err) {
                alert(`Error: ${err}`);
            }
        }
    </script>
</body>

</html>